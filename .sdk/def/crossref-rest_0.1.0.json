{
  "openapi": "3.0.3",
  "info": {
    "title": "Crossref REST API",
    "description": "The Crossref REST API allows users to search and retrieve metadata for scholarly works, including DOIs, ISSNs, and funder identifiers. It provides access to various endpoints that expose data on works, journals, funders, and more, facilitating sophisticated searches and integrations for research purposes.",
    "version": "1.0.0",
    "contact": {
      "name": "Crossref API Support",
      "url": "https://www.crossref.org/documentation/retrieve-metadata/rest-api/"
    },
    "license": {
      "name": "Crossref Metadata License",
      "url": "https://www.crossref.org/documentation/retrieve-metadata/rest-api/rest-api-metadata-license-information/"
    }
  },
  "servers": [
    {
      "url": "https://api.crossref.org",
      "description": "Crossref REST API Production Server"
    }
  ],
  "paths": {
    "/works": {
      "get": {
        "summary": "Search and retrieve works metadata",
        "description": "Returns a list of works (scholarly articles, books, etc.) matching the search criteria. Supports filtering, sorting, and pagination.",
        "operationId": "getWorks",
        "tags": [
          "Works"
        ],
        "parameters": [
          {
            "name": "query",
            "in": "query",
            "description": "Search query string",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "rows",
            "in": "query",
            "description": "Number of results to return per page (max 1000)",
            "required": false,
            "schema": {
              "type": "integer",
              "default": 20,
              "maximum": 1000
            }
          },
          {
            "name": "offset",
            "in": "query",
            "description": "Offset for pagination",
            "required": false,
            "schema": {
              "type": "integer",
              "default": 0
            }
          },
          {
            "name": "filter",
            "in": "query",
            "description": "Filter results by specific criteria (e.g., from-pub-date:2020, type:journal-article)",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "sort",
            "in": "query",
            "description": "Sort results by field (e.g., published, relevance, score)",
            "required": false,
            "schema": {
              "type": "string",
              "enum": [
                "relevance",
                "score",
                "published",
                "deposited",
                "indexed",
                "updated"
              ]
            }
          },
          {
            "name": "order",
            "in": "query",
            "description": "Sort order",
            "required": false,
            "schema": {
              "type": "string",
              "enum": [
                "asc",
                "desc"
              ],
              "default": "desc"
            }
          },
          {
            "name": "mailto",
            "in": "query",
            "description": "Email address for polite pool access (recommended for better performance)",
            "required": false,
            "schema": {
              "type": "string",
              "format": "email"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response with works metadata",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/WorksResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request - invalid parameters"
          },
          "404": {
            "description": "No results found"
          },
          "503": {
            "description": "Service unavailable"
          }
        }
      }
    },
    "/works/{doi}": {
      "get": {
        "summary": "Get metadata for a specific work by DOI",
        "description": "Returns detailed metadata for a single work identified by its DOI",
        "operationId": "getWorkByDoi",
        "tags": [
          "Works"
        ],
        "parameters": [
          {
            "name": "doi",
            "in": "path",
            "description": "Digital Object Identifier (DOI) of the work",
            "required": true,
            "schema": {
              "type": "string"
            },
            "example": "10.1037/0003-066X.59.1.29"
          },
          {
            "name": "mailto",
            "in": "query",
            "description": "Email address for polite pool access",
            "required": false,
            "schema": {
              "type": "string",
              "format": "email"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response with work metadata",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/WorkResponse"
                }
              }
            }
          },
          "404": {
            "description": "DOI not found"
          },
          "503": {
            "description": "Service unavailable"
          }
        }
      }
    },
